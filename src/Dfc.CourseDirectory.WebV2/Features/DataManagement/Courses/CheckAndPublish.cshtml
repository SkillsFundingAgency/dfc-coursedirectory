@using Dfc.CourseDirectory.WebV2.Features.DataManagement.Courses.CheckAndPublish
@model ViewModel
@{
    ViewContext.SetLayoutData(title: "Check and publish your course data");
}

<govuk-error-summary>
    <govuk-error-summary-item asp-for="Confirm" />
</govuk-error-summary>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-xl">Publish your venue data</h1>
    </div>
</div>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <form asp-action="CheckAndPublish" asp-all-route-data="@ProviderContext.RouteValues">

            <p class="govuk-body">Publishing your courses will add them to Publish to the course directory.</p>

            <div class="pttcd-dm-publish-summary">
                <div class="pttcd-dm-publish-summary__row">
                    <div class="pttcd-dm-publish-summary__row__header govuk-!-width-two-thirds">
                        <div class="pttcd-dm-publish-summary__row__label">Your course data file</div>
                        <div><span data-testid="RowCount">@Model.RowCount</span> venues</div>
                    </div>
                    <div class="pttcd-dm-publish-summary__row__details">
                        <govuk-details>
                            <govuk-details-summary>
                                View list of courses
                            </govuk-details-summary>
                            <govuk-details-text>
                                TODO
                            </govuk-details-text>
                        </govuk-details>
                    </div>
                </div>
            </div>
        
            <govuk-warning-text icon-fallback-text="warning">
                Publishing will replace all of your courses on Publish to the course directory
            </govuk-warning-text>

            <govuk-checkboxes class="govuk-checkboxes--small" asp-for="Confirm">
                <govuk-checkboxes-fieldset>
                    <govuk-checkboxes-fieldset-legend class="govuk-fieldset__legend--m">
                        <h2 class="govuk-fieldset__heading">
                            Are you sure?
                        </h2>
                    </govuk-checkboxes-fieldset-legend>
                </govuk-checkboxes-fieldset>
                <govuk-checkboxes-item value="@(true)">
                    Yes - I want to publish these courses
                </govuk-checkboxes-item>
            </govuk-checkboxes>
        
            <govuk-button type="submit" prevent-double-click="true" id="pttcd-delete-courseupload__delete-btn" class="govuk-!-margin-right-3">Publish</govuk-button>

            <govuk-button asp-controller="ProviderDashboard" asp-action="Index" asp-all-route-data="@ProviderContext.RouteValues" class="govuk-button--secondary" data-testid="cancel-btn">Cancel</govuk-button>
        </form>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        function enableDeleteBtn() {
            $('#pttcd-delete-courseupload__delete-btn').attr(
                'disabled',
                $('#Confirm').is(':checked') ? null : 'disabled');
        }

        // timeout is required otherwise the _checked_ property check doesn't return the correct value
        // (maybe GDS scripts need chance to run?)
        setTimeout(enableDeleteBtn, 100);

        $('#Confirm').change(enableDeleteBtn);
    </script>
}
