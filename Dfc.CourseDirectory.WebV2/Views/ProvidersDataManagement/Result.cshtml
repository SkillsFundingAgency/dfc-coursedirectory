@model Dfc.CourseDirectory.WebV2.ViewModels.DataManagement.Providers.Result.ViewModel
@{
    ViewBag.Title = "Uploading active providers";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <div class="govuk-panel govuk-panel--confirmation">
            @if (Model.UploadResultSummary.Total != 0)
            {
                <h1 class="govuk-panel__title">
                    @Model.UploadResultSummary.Total  providers have been uploaded
                </h1>
                <div class="govuk-panel__body">
                    <p> @Model.UploadResultSummary.NewProviders new providers have been onboarded </p>
                    <p> @Model.UploadResultSummary.ChangeToStatus providers have moved from registered to onboarded </p>
                    <p> @Model.UploadResultSummary.ChangeToType providers have changed provider type </p>
                    <p> @Model.UploadResultSummary.ChangeToStatusAndType providers have moved from registered to onboarded and have also changed provider type </p>
                </div>
            } 
            else
            {
                <h1 class="govuk-panel__title">
                    No new providers have been identified from this file
                </h1>
                <div class="govuk-panel__body">
                    <p>This usually means that there are no new providers who meet the criteria and you do not need to do anything further </p>
                </div>
            }
            
        </div>
        <div class="govuk-!-margin-top-9">
            <label class="govuk-label--m">
                Next step
            </label>
            <ul class="govuk-list pttcd-list--medium govuk-!-margin-top-4">
                <li><a asp-controller="ProviderReports" asp-action="ProviderTypeReport" class="govuk-link">Review provider type report</a></li>
                <li><a asp-controller="HelpdeskDashboard" asp-action="Dashboard" class="govuk-link">Back to helpdesk dashboard</a></li>
            </ul>
          
            
        </div>
    </div>
</div>

