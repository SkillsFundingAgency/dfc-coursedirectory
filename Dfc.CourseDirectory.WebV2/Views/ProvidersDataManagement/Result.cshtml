@model Dfc.CourseDirectory.WebV2.ViewModels.DataManagement.Providers.Result.ViewModel
@{
    ViewBag.Title = "Uploading active providers";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <div class="govuk-panel govuk-panel--confirmation">
            <h1 class="govuk-panel__title">
                providers have been uploaded
            </h1>
            <div class="govuk-panel__body">
                <p> new providers have been onboarded </p>
                <p> providers have moved from registered to onboarded </p>
                <p> providers have changed provider type </p>
                <p> providers have moved from registered to onboarded and have also changed provider type </p>

            </div>
        </div>
        <div class="govuk-!-margin-top-9">
            <label class="govuk-label--m">
                Next step
            </label>
            <ul class="govuk-list pttcd-list--medium govuk-!-margin-top-4">
                <li><a asp-controller="ProviderReports" asp-action="ProviderTypeReport" class="govuk-link">Review provider type report</a></li>
                <li><a asp-controller="HelpdeskDashboard" asp-action="Dashboard" class="govuk-link">Back to helpdesk dashboard</a></li>
            </ul>
          
            
        </div>
    </div>
</div>

